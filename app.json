{
  "expo": {
    "name": "MacroForge",
    "slug": "macrozone",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/macroforge_logo.png",
    "scheme": "macrozone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/macroforge_logo.png"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f0f23",
        "foregroundImage": "./assets/images/macroforge_logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.bolucodes.macrozone"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f0f23",
          "image": "./assets/images/macroforge_logo.png",
          "android": {
            "imageWidth": 120
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "70891a21-bca3-4fc3-87a3-44307db3bb77"
      }
    },
    "owner": "bolucodes",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/70891a21-bca3-4fc3-87a3-44307db3bb77"
    }
  }
}
